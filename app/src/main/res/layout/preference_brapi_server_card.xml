<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header row: radio button + name/url + status icon -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/brapi_card_logo"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/brapi_card_enable" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/brapi_card_display_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_size_medium"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/brapi_card_url"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_small"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="?android:attr/textColorSecondary" />

            </LinearLayout>

            <ImageView
                android:id="@+id/brapi_card_status_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Action chips row -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/brapi_card_chip_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:chipSpacingVertical="8dp"
            app:chipSpacingHorizontal="4dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/brapi_card_chip_compat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="false"
                app:chipIcon="@drawable/ic_server_compare"
                app:chipIconSize="20dp"
                app:ensureMinTouchTargetSize="false"
                app:closeIconVisible="false"
                app:chipBackgroundColor="?attr/selectableChipBackground"
                app:chipStrokeColor="?attr/selectableChipStroke"
                app:chipStrokeWidth="2dp"
                android:text="@string/brapi_chip_compatibility" />

            <com.google.android.material.chip.Chip
                android:id="@+id/brapi_card_chip_share"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="false"
                app:chipIcon="@drawable/ic_share"
                app:chipIconSize="20dp"
                app:ensureMinTouchTargetSize="false"
                app:closeIconVisible="false"
                app:chipBackgroundColor="?attr/selectableChipBackground"
                app:chipStrokeColor="?attr/selectableChipStroke"
                app:chipStrokeWidth="2dp"
                android:text="@string/brapi_chip_share" />

            <com.google.android.material.chip.Chip
                android:id="@+id/brapi_card_chip_edit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="false"
                app:chipIcon="@drawable/square_edit_outline"
                app:chipIconSize="20dp"
                app:ensureMinTouchTargetSize="false"
                app:closeIconVisible="false"
                app:chipBackgroundColor="?attr/selectableChipBackground"
                app:chipStrokeColor="?attr/selectableChipStroke"
                app:chipStrokeWidth="2dp"
                android:text="@string/brapi_chip_edit" />

            <com.google.android.material.chip.Chip
                android:id="@+id/brapi_card_chip_auth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="false"
                app:chipIconSize="20dp"
                app:ensureMinTouchTargetSize="false"
                app:closeIconVisible="false"
                app:chipBackgroundColor="?attr/selectableChipBackground"
                app:chipStrokeColor="?attr/selectableChipStroke"
                app:chipStrokeWidth="2dp" />

        </com.google.android.material.chip.ChipGroup>

    </LinearLayout>

</androidx.cardview.widget.CardView>
