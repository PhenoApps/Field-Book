<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp">

            <!-- Base URL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/brapi_manual_url_input_layout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/brapi_base_url">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/brapi_manual_url_edit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:imeOptions="actionNext" />

                </com.google.android.material.textfield.TextInputLayout>

                <ImageButton
                    android:id="@+id/brapi_manual_url_scan_btn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/dialog_scan"
                    android:src="@drawable/ic_tb_barcode_scan"
                    android:padding="6dp" />

            </LinearLayout>

            <!-- Display Name -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/brapi_manual_display_name_layout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/brapi_display_name">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/brapi_manual_display_name_edit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:imeOptions="actionNext"
                        android:nextFocusForward="@id/brapi_manual_oidc_url_edit" />

                </com.google.android.material.textfield.TextInputLayout>

                <ImageButton
                    android:id="@+id/brapi_manual_display_name_auto_btn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/brapi_edit_display_name_server"
                    android:src="@drawable/database_search"
                    android:padding="6dp" />

            </LinearLayout>

            <!-- BrAPI Version exposed dropdown -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/brapi_manual_version_layout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/preferences_brapi_version">

                <AutoCompleteTextView
                    android:id="@+id/brapi_manual_version_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:cursorVisible="false"
                    android:focusable="false" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- OIDC Flow exposed dropdown -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/brapi_manual_oidc_flow_layout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:hint="@string/preferences_brapi_oidc_flow">

                <AutoCompleteTextView
                    android:id="@+id/brapi_manual_oidc_flow_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:cursorVisible="false"
                    android:focusable="false" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- OIDC Discovery URL -->
            <LinearLayout
                android:id="@+id/brapi_manual_oidc_url_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/brapi_manual_oidc_url_layout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/brapi_oidc_url">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/brapi_manual_oidc_url_edit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:imeOptions="actionNext"
                        android:nextFocusForward="@id/brapi_manual_oidc_client_id_edit" />

                </com.google.android.material.textfield.TextInputLayout>

                <ImageButton
                    android:id="@+id/brapi_manual_oidc_url_scan_btn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/dialog_scan"
                    android:src="@drawable/ic_tb_barcode_scan"
                    android:padding="6dp" />

            </LinearLayout>

            <!-- OIDC Client ID -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/brapi_manual_oidc_client_id_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/brapi_oidc_clientid"
                android:layout_marginBottom="8dp"
                app:placeholderText="@string/traits_create_optional">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/brapi_manual_oidc_client_id_edit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:imeOptions="actionNext" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- OIDC Scope -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/brapi_manual_oidc_scope_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/brapi_oidc_scope"
                android:layout_marginBottom="8dp"
                app:placeholderText="@string/traits_create_optional">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/brapi_manual_oidc_scope_edit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:imeOptions="actionNext" />

            </com.google.android.material.textfield.TextInputLayout>


        </LinearLayout>

    </ScrollView>

    <!-- Sticky button bar — always visible above keyboard -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <Button
            android:id="@+id/brapi_btn_cancel"
            style="?attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dialog_cancel" />

        <Button
            android:id="@+id/brapi_btn_authorize"
            style="?attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/brapi_save_authorize" />

    </LinearLayout>

</LinearLayout>
