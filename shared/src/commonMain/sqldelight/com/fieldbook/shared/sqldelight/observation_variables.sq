-- observation_variables.sq

CREATE TABLE observation_variables (
  internal_id_observation_variable INTEGER PRIMARY KEY AUTOINCREMENT,
  observation_variable_name TEXT,
  observation_variable_field_book_format TEXT,
  default_value TEXT,
  visible TEXT,
  position INTEGER,
  external_db_id TEXT,
  trait_data_source TEXT,
  additional_info TEXT,
  common_crop_name TEXT,
  language TEXT,
  data_type TEXT,
  observation_variable_db_id TEXT,
  ontology_db_id TEXT,
  ontology_name TEXT,
  observation_variable_details TEXT
);

CREATE TABLE observation_variable_attributes (
  internal_id_observation_variable_attribute INTEGER PRIMARY KEY AUTOINCREMENT,
  observation_variable_attribute_name TEXT NOT NULL UNIQUE
);

CREATE TABLE observation_variable_values (
  internal_id_observation_variable_value INTEGER PRIMARY KEY AUTOINCREMENT,
  observation_variable_db_id INTEGER NOT NULL REFERENCES observation_variables(internal_id_observation_variable),
  observation_variable_attribute_db_id INTEGER NOT NULL REFERENCES observation_variable_attributes(internal_id_observation_variable_attribute),
  observation_variable_attribute_value TEXT
);

getAllTraits:
SELECT * FROM observation_variables;

getAllTraitsOrdered:
SELECT * FROM observation_variables ORDER BY position ASC;

getTraitById:
SELECT * FROM observation_variables
WHERE internal_id_observation_variable = ?;

getTraitWithAttributesById:
SELECT ov.*,
  MIN(CASE WHEN ova.observation_variable_attribute_name = 'validValuesMin' THEN ovv.observation_variable_attribute_value END) AS minimum,
  MAX(CASE WHEN ova.observation_variable_attribute_name = 'validValuesMax' THEN ovv.observation_variable_attribute_value END) AS maximum,
  GROUP_CONCAT(CASE WHEN ova.observation_variable_attribute_name = 'category' THEN ovv.observation_variable_attribute_value END) AS categories,
  MAX(CASE WHEN ova.observation_variable_attribute_name = 'closeKeyboardOnOpen' THEN ovv.observation_variable_attribute_value END) AS closeKeyboardOnOpen,
  MAX(CASE WHEN ova.observation_variable_attribute_name = 'cropImage' THEN ovv.observation_variable_attribute_value END) AS cropImage
FROM observation_variables ov
LEFT JOIN observation_variable_values ovv ON ov.internal_id_observation_variable = ovv.observation_variable_db_id
LEFT JOIN observation_variable_attributes ova ON ovv.observation_variable_attribute_db_id = ova.internal_id_observation_variable_attribute
WHERE ov.internal_id_observation_variable = ?
GROUP BY ov.internal_id_observation_variable;

getAllTraitsWithAttributes:
SELECT ov.*,
  MIN(CASE WHEN ova.observation_variable_attribute_name = 'validValuesMin' THEN ovv.observation_variable_attribute_value END) AS minimum,
  MAX(CASE WHEN ova.observation_variable_attribute_name = 'validValuesMax' THEN ovv.observation_variable_attribute_value END) AS maximum,
  GROUP_CONCAT(CASE WHEN ova.observation_variable_attribute_name = 'category' THEN ovv.observation_variable_attribute_value END) AS categories,
  MAX(CASE WHEN ova.observation_variable_attribute_name = 'closeKeyboardOnOpen' THEN ovv.observation_variable_attribute_value END) AS closeKeyboardOnOpen,
  MAX(CASE WHEN ova.observation_variable_attribute_name = 'cropImage' THEN ovv.observation_variable_attribute_value END) AS cropImage
FROM observation_variables ov
LEFT JOIN observation_variable_values ovv ON ov.internal_id_observation_variable = ovv.observation_variable_db_id
LEFT JOIN observation_variable_attributes ova ON ovv.observation_variable_attribute_db_id = ova.internal_id_observation_variable_attribute
GROUP BY ov.internal_id_observation_variable;

updateTraitVisibility:
UPDATE observation_variables SET visible = ? WHERE internal_id_observation_variable = ?;

updateTraitPosition:
UPDATE observation_variables SET position = ? WHERE internal_id_observation_variable = ?;

deleteTrait:
DELETE FROM observation_variables WHERE internal_id_observation_variable = ?;

-- Return all trait names (used to pick a unique copy name)
getAllTraitNames:
SELECT observation_variable_name FROM observation_variables;

-- Return max position (or -1 if none)
getMaxPositionFromTraits:
SELECT COALESCE(MAX(position), -1) FROM observation_variables;

-- Insert a trait; preserve most fields except internal id
insertTrait:
INSERT INTO observation_variables(
  observation_variable_name,
  observation_variable_field_book_format,
  default_value,
  visible,
  position,
  external_db_id,
  trait_data_source,
  additional_info,
  common_crop_name,
  language,
  data_type,
  observation_variable_db_id,
  ontology_db_id,
  ontology_name,
  observation_variable_details
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getTraitByName:
SELECT * FROM observation_variables WHERE observation_variable_name = ?;

getTraitByNameAndPosition:
SELECT * FROM observation_variables
WHERE observation_variable_name = ? AND position = ?
ORDER BY internal_id_observation_variable DESC
LIMIT 1;

getAttributeIdByName:
SELECT internal_id_observation_variable_attribute FROM observation_variable_attributes WHERE observation_variable_attribute_name = ?;

insertObservationVariableAttribute:
INSERT INTO observation_variable_attributes(observation_variable_attribute_name) VALUES (?);

insertObservationVariableValue:
INSERT INTO observation_variable_values(observation_variable_db_id, observation_variable_attribute_db_id, observation_variable_attribute_value)
VALUES (?, ?, ?);

updateObservationVariableValue:
UPDATE observation_variable_values SET observation_variable_attribute_value = ? WHERE observation_variable_db_id = ? AND observation_variable_attribute_db_id = ?;

deleteObservationVariableValue:
DELETE FROM observation_variable_values WHERE observation_variable_db_id = ? AND observation_variable_attribute_db_id = ?;

updateTrait:
UPDATE observation_variables
SET observation_variable_name = ?,
  observation_variable_field_book_format = ?,
  default_value = ?,
  observation_variable_details = ?
WHERE internal_id_observation_variable = ?;
